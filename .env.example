# Copy to .env.development for local Docker dev. In production, set these in
# your hosting provider (Vercel dashboard or `vercel env add`).
#
# Defaults below match infra/compose.yaml (Postgres + mailpit). Edit only if
# you change ports/credentials there.

# Postgres (Docker via infra/compose.yaml).
# DATABASE_URL must be inlined — dotenv used by node-pg-migrate doesn't expand
# ${VAR} references. Update both sides if you change POSTGRES_*.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=local_user
POSTGRES_DB=sacola_dev
POSTGRES_PASSWORD=local_password
DATABASE_URL=postgresql://local_user:local_password@localhost:5432/sacola_dev

# Application
SESSION_COOKIE_NAME=sacola_session_id
TZ=America/Sao_Paulo

# Email transport (SMTP). Locally mailpit runs in compose (inspect captured
# messages at http://localhost:8025). In production, point at Resend
# (smtp.resend.com:465, USER=resend, PASS=<api key>).
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=Sacola <no-reply@sacola.dev>

# Test orchestrator expectations (asserted by tests/integration/api/v1/status).
POSTGRES_VERSION=16.6
POSTGRES_MAX_CONNECTIONS=100
