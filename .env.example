# Copy to .env.development for local Docker dev, or set in your hosting provider for prod.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_DB=
POSTGRES_PASSWORD=
DATABASE_URL=

SESSION_COOKIE_NAME=sacola_session_id
TZ=America/Sao_Paulo

# Email transport (SMTP). Locally mailpit runs in compose; in prod point at
# Resend (smtp.resend.com:465, USER=resend, PASS=<api key>).
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
