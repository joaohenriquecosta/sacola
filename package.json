{
  "name": "sacola",
  "version": "0.1.0",
  "private": true,
  "description": "Open source operational management for greengrocers: WhatsApp-driven orders, distributed picking, and motorcycle delivery.",
  "license": "MIT",
  "author": "João Henrique Costa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joaohenriquecosta/sacola.git"
  },
  "bugs": {
    "url": "https://github.com/joaohenriquecosta/sacola/issues"
  },
  "homepage": "https://github.com/joaohenriquecosta/sacola#readme",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:db && npm run migrations:up && next dev",
    "postdev": "npm run services:stop",
    "build": "next build",
    "vercel-build": "DATABASE_URL=\"$DATABASE_URL_NON_POOLING\" node-pg-migrate -m infra/migrations up && next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:db": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate --envPath .env.development -m infra/migrations up",
    "migrations:up:dry": "node-pg-migrate --envPath .env.development -m infra/migrations --dry-run up",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "node infra/scripts/cleanup-next-dev-ports.js && npm run services:up && npm run services:wait:db && npm run migrations:up && TEST_BASE_URL=http://127.0.0.1:3000 concurrently -n next,jest --hide next -k -s command-jest \"next dev --hostname 127.0.0.1 --port 3000\" \"node infra/scripts/wait-for-next-dev.js && jest --runInBand --verbose\"",
    "posttest": "npm run services:stop",
    "test:watch:server": "node infra/scripts/open-next-watch-server.js",
    "test:watch:server:stop": "node infra/scripts/stop-next-watch-server.js",
    "test:watch": "node infra/scripts/cleanup-next-dev-ports.js && npm run services:up && npm run test:watch:server && node infra/scripts/wait-for-next-dev.js && TEST_BASE_URL=http://127.0.0.1:3000 jest --runInBand --watchAll --verbose",
    "posttest:watch": "npm run test:watch:server:stop && npm run services:stop",
    "prepare": "husky"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@types/bcryptjs": "^2.4.6",
    "async-retry": "^1.3.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/async-retry": "^1.4.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
